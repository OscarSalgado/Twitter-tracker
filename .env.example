# Credenciales de la cuenta de Twitter/X que usará la instancia para leer los
# tuits de las cuentas seguidas. Usa preferiblemente una cuenta secundaria,
# nunca tu cuenta personal principal (ver README para más detalle).
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# Cada cuántos minutos se revisan las cuentas seguidas en busca de tuits nuevos.
POLL_INTERVAL_MINUTES=15

# Ruta de la base de datos SQLite (se persiste en el volumen ./data).
DATABASE_URL=sqlite:///./data/tracker.db

# Notificaciones por Telegram (opcional). Déjalo vacío para desactivarlas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Usuario/contraseña para proteger el panel web (autenticación básica).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me
